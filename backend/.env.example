# Environment variables for EmpireBox

# ===================
# Database
# ===================
DATABASE_URL=sqlite:///./empirebox.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/empirebox

# ===================
# Security
# ===================
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# MarketF Settings
# ===================
MARKETF_FEE_PERCENT=8.0
MARKETF_ESCROW_RELEASE_DELAY_HOURS=48

# ===================
# Stripe (Payments)
# ===================
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ===================
# EasyPost (Shipping)
# ===================
EASYPOST_API_KEY=your_easypost_api_key_here
EASYPOST_TEST_KEY=your_easypost_test_key_here
EASYPOST_TEST_MODE=true

# ===================
# eBay API
# ===================
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ===================
# Email (for sending labels)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ===================
# Cloudflare Email (alternative)
# ===================
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=

# ===================
# AI Services
# ===================
GROK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# ===================
# Economic Intelligence
# ===================
ECONOMIC_ENABLED=true
ECONOMIC_DEFAULT_BALANCE=1000.00
ECONOMIC_TOKEN_INPUT_PRICE_PER_1M=2.50
ECONOMIC_TOKEN_OUTPUT_PRICE_PER_1M=10.00
ECONOMIC_COMPUTE_COST_PER_MINUTE=0.10
ECONOMIC_LISTING_COMMISSION_RATE=0.05

# ===================
# Quality Evaluation
# ===================
QUALITY_EVAL_ENABLED=true
QUALITY_EVAL_MODEL=gpt-4-turbo-preview

# ===================
# API
# ===================
API_HOST=0.0.0.0
API_PORT=8000