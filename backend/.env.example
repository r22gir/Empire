# Environment variables for EmpireBox

# ===================
# Database
# ===================
DATABASE_URL=sqlite:///./empirebox.db
# For production, use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/empirebox

# ===================
# Security
# ===================
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================
# MarketF Settings
# ===================
MARKETF_FEE_PERCENT=8.0
MARKETF_ESCROW_RELEASE_DELAY_HOURS=48

# ===================
# Stripe (Payments)
# ===================
STRIPE_API_KEY=your_stripe_api_key_here
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ===================
# EmpirePay — Crypto Payments (System A: canonical, SQLAlchemy + PostgreSQL)
# ===================
# Master seed for deterministic wallet derivation (HMAC-SHA256)
# MUST be set for crypto payments to work — generates 503 error if missing
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CRYPTO_MASTER_SEED=
CRYPTO_PAYMENT_EXPIRY_MINUTES=60

# ===================
# EmpirePay — Crypto Checkout (System B: legacy, SQLite)
# ===================
# Static wallet addresses for lightweight crypto checkout (legacy system)
# These are used by /crypto-checkout/* endpoints (customer-facing)
CRYPTO_BTC_ADDRESS=
CRYPTO_ETH_ADDRESS=
CRYPTO_SOL_ADDRESS=
CRYPTO_USDT_TRC20_ADDRESS=
CRYPTO_USDT_ERC20_ADDRESS=
CRYPTO_USDC_ETH_ADDRESS=

# ===================
# EasyPost (Shipping)
# ===================
EASYPOST_API_KEY=your_easypost_api_key_here
EASYPOST_TEST_KEY=your_easypost_test_key_here
EASYPOST_TEST_MODE=true

# ===================
# eBay API
# ===================
EBAY_APP_ID=
EBAY_CERT_ID=
EBAY_DEV_ID=

# ===================
# Email (for sending labels)
# ===================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# ===================
# Cloudflare Email (alternative)
# ===================
CLOUDFLARE_API_KEY=
CLOUDFLARE_ZONE_ID=

# ===================
# AI Services
# ===================
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
XAI_MODEL=grok-4-fast-non-reasoning
XAI_MAX_TOKENS=8192
GROK_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# MiniMax AI Provider — set MAX_PRIMARY_PROVIDER=minimax to activate
# MINIMAX_API_KEY=your_minimax_key_here
# MINIMAX_BASE_URL=https://api.minimax.io/v1
# MINIMAX_MODEL=MiniMax-M2.7
# MINIMAX_FALLBACK_MODEL=MiniMax-M2.7-highspeed
# MAX_PRIMARY_PROVIDER=minimax  # uncomment to make MiniMax the primary provider
# MAX_DISABLE_XAI=true  # uncomment to disable xAI (credits unavailable)

# ===================
# Economic Intelligence
# ===================
ECONOMIC_ENABLED=true
ECONOMIC_DEFAULT_BALANCE=1000.00
ECONOMIC_TOKEN_INPUT_PRICE_PER_1M=2.50
ECONOMIC_TOKEN_OUTPUT_PRICE_PER_1M=10.00
ECONOMIC_COMPUTE_COST_PER_MINUTE=0.10
ECONOMIC_LISTING_COMMISSION_RATE=0.05

# ===================
# Quality Evaluation
# ===================
QUALITY_EVAL_ENABLED=true
QUALITY_EVAL_MODEL=gpt-4-turbo-preview

# ===================
# API
# ===================
API_HOST=0.0.0.0
API_PORT=8000
