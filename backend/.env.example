# Database
DATABASE_URL=sqlite:///./marketforge.db

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# eBay API
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
EBAY_DEV_ID=your_ebay_dev_id
EBAY_OAUTH_REDIRECT_URI=http://localhost:8000/auth/ebay/callback

# Facebook Marketplace
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Mercari (if API available)
MERCARI_API_KEY=your_mercari_api_key

# Poshmark (if API available)
POSHMARK_API_KEY=your_poshmark_api_key

# File Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760  # 10MB
