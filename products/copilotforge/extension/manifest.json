{
  "manifest_version": 2,
  "name": "CoPilotForge",
  "version": "2.0.0",
  "description": "Auto-save GitHub Copilot chats with RAM monitoring - Empire Tools",
  "author": "Empire Tools",

  "browser_specific_settings": {
    "gecko": {
      "id": "copilotforge@empire.tools"
    }
  },

  "permissions": [
    "activeTab",
    "storage",
    "nativeMessaging",
    "tabs",
    "contextMenus",
    "alarms"
  ],

  "content_scripts": [
    {
      "matches": ["https://github.com/copilot*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },

  "browser_action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    }
  },

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
